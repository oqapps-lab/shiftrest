{
  "expo": {
    "name": "ShiftRest",
    "slug": "shiftrest",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "shiftrest",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#FCF9F6"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.gazetastreet.shiftrest",
      "usesAppleSignIn": true
    },
    "android": {
      "package": "com.gazetastreet.shiftrest",
      "adaptiveIcon": {
        "backgroundColor": "#FCF9F6"
      }
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-splash-screen",
      [
        "expo-notifications",
        {
          "color": "#FCF9F6",
          "defaultChannel": "default"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
